# Server
PORT=3000
NODE_ENV=development
# Comma-separated list of allowed CORS origins (the Vite dev server)
CORS_ORIGIN=http://localhost:5173

# Postgres (consumed by docker-compose and Prisma)
POSTGRES_USER=sukipass
POSTGRES_PASSWORD=sukipass
POSTGRES_DB=sukipass
DATABASE_URL=postgresql://sukipass:sukipass@localhost:5432/sukipass?schema=public
