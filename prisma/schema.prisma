datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

// =====================
// ENUMS
// =====================

enum Role {
  ADMIN
  BUSINESS_OWNER
  STAFF
  CUSTOMER
}

// =====================
// USER
// =====================

model User {
  id            String   @id @default(uuid()) @db.Uuid
  accountNumber String   @unique
  name          String?
  username      String   @unique
  email         String?  @unique
  password      String
  role          Role
  isTemporary   Boolean  @default(false)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  businesses            Business[]         @relation("UserBusinesses")
  staffProfile          StaffProfile?
  customerCampaigns     CustomerCampaign[]
  performedTransactions Transaction[]      @relation("PerformedTransactions")
}

// =====================
// BUSINESS
// =====================

model Business {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  address   String
  category       String?
  contactNumber  String?
  ownerId   String   @db.Uuid

  profile        Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  owner        User           @relation("UserBusinesses", fields: [ownerId], references: [id], onDelete: Cascade)
  staffMembers StaffProfile[]
  campaigns    Campaign[]
  transactions Transaction[]
}

// =====================
// STAFF PROFILE
// =====================

model StaffProfile {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @unique @db.Uuid
  businessId String   @db.Uuid

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

// =====================
// TRANSACTION
// =====================

enum TransactionType {
  STAMP
  REDEEM
}

model Transaction {
  id                 String          @id @default(uuid()) @db.Uuid
  customerCampaignId String          @db.Uuid
  businessId         String          @db.Uuid
  performedById      String          @db.Uuid
  type               TransactionType
  stampCount         Int             @default(1)
  amount             Decimal?        @db.Decimal(10, 2)

  createdAt          DateTime        @default(now())

  // Relations
  customerCampaign CustomerCampaign @relation(fields: [customerCampaignId], references: [id], onDelete: Cascade)
  business         Business         @relation(fields: [businessId], references: [id], onDelete: Cascade)
  performedBy      User             @relation("PerformedTransactions", fields: [performedById], references: [id], onDelete: Cascade)
}

// =====================
// CAMPAIGN
// =====================

model Campaign {
  id          String   @id @default(uuid()) @db.Uuid
  businessId  String   @db.Uuid
  name        String
  description String?
  stampGoal   Int
  reward      String
  isActive    Boolean  @default(true)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  business          Business           @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customerCampaigns CustomerCampaign[]
}

// =====================
// CUSTOMER CAMPAIGN
// =====================

model CustomerCampaign {
  id          String   @id @default(uuid()) @db.Uuid
  customerId  String   @db.Uuid
  campaignId  String   @db.Uuid
  stampCount  Int      @default(0)
  isCompleted Boolean  @default(false)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  customer     User          @relation(fields: [customerId], references: [id], onDelete: Cascade)
  campaign     Campaign      @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@unique([customerId, campaignId])
}